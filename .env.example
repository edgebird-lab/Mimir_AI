# ============================================================================
#  Mimir — environment template.  Copy to .env  (which is .gitignored).
#  The install script generates the tokens for you; you rarely edit this by hand.
#      cp .env.example .env && ./install.sh        (Linux)
#  NEVER commit .env or put real secrets in this file.
# ============================================================================

# --- Build -------------------------------------------------------------------
# llama.cpp release tag to build the Vulkan inference image from (pinned).
LLAMACPP_REF=b9964
# Parallel build jobs for the llama.cpp compile (Vulkan mul_mm shader is RAM-heavy; 4 is safe on 16 GB).
BUILD_JOBS=4

# --- Model -------------------------------------------------------------------
# Active chat model file name inside the mimir_models volume. Switchable at runtime
# from the web UI (⚙ Einstellungen → Modell). Downloaded by scripts/fetch-verify-model.sh
# or from the UI. Pick one that fits your VRAM (the UI suggests fitting models).
MIMIR_MODEL_FILE=Qwen3.6-35B-A3B-UD-IQ4_XS.gguf
# Embedding model (small, CPU/GPU; used for document RAG + memory).
MIMIR_EMBED_MODEL_FILE=nomic-embed-text-v1.5.Q5_K_M.gguf
# Inference context window (q8 KV cache keeps this within ~24 GB VRAM alongside the model).
MIMIR_CTX=49152

# --- Contact (polite pool for OpenAlex academic search; optional) -----------
MIMIR_CONTACT_EMAIL=you@example.com

# --- Tokens: LEAVE BLANK — the install script fills these with fresh secrets --
# They authenticate the containers to the host daemons over local Unix sockets.
# Generate any missing one with:  python3 -c "import secrets;print(secrets.token_urlsafe(24))"
MIMIR_SANDBOX_TOKEN=
MIMIR_WORKSPACE_TOKEN=
MIMIR_DOCPROC_TOKEN=
MIMIR_WEBFETCH_TOKEN=
MIMIR_CONTROL_TOKEN=
