# ============================================================================
#  Mimir — .gitignore
#  This repo is PUBLIC. Nothing secret, personal, or huge may ever be committed.
# ============================================================================

# ---- Secrets (NEVER in the repo or any container mount) --------------------
.env
*.env
!.env.example
secrets/
*.pem
*.key
*.pfx
id_*
# ed25519 skill-signing material is INSTALL-LOCAL: generated by scripts/sign-skills.py
# on first setup, never shipped. (SkillLibrary is fail-closed, so a fresh clone loads
# no skills until you run build-skill-registry.py + sign-skills.py.)
/_keys/
skills/_keys/
skills/registry.sig
/state/
gateway.token

# ---- Model weights (50 GB+; fetched by scripts/fetch-verify-model.sh) ------
models/
*.gguf

# ---- Firecracker guest artifacts (~1.6 GB; built by sandbox/build-*.sh) ----
sandbox/fc/
sandbox/rootfs/*.ext4
sandbox/kernel/*
*.ext4
*.img
vmlinux*

# ---- User runtime data & generated outputs (personal / not source) ---------
project/in/*
project/out/*
!project/in/.gitkeep
!project/out/.gitkeep
project/data/
project/docs/
project/media-task/

# ---- Python / tooling caches -----------------------------------------------
__pycache__/
*.pyc
.venv/
venv/
*.hfvenv/
.pytest_cache/
*.egg-info/
.mypy_cache/
.ruff_cache/

# ---- Node (playwright etc., dev-only) --------------------------------------
node_modules/

# ---- Local runtime / misc --------------------------------------------------
/srv-local/
*.log
.DS_Store
Thumbs.db

# Built Windows installer (published via Releases, not committed)
dist/
installer/
MimirInstaller.exe
*.pdb

# ---- Native Windows runtime (downloaded/built per-machine; never source) ----
# Populated by windows-native\Setup-Mimir.ps1 / Build-Installer.ps1 - not committed.
/runtime/
/bin/
/data/
/run/
